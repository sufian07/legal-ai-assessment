# Copy to .env and fill in the values. .env is gitignored.
# Every env var the system reads is listed here — if a setting is read
# in code but missing from this file, that's a bug in TASK-000.

# Anthropic API
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OCR
OCR_CONFIDENCE_FLOOR=60          # 0-100; pages below this are retried with TrOCR
OCR_LANG=eng                      # Tesseract language hint

# Embeddings & retrieval
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHROMA_DB_PATH=.chroma
RETRIEVAL_K=8
LOW_CONFIDENCE_PENALTY=0.7        # score multiplier on chunks from low-confidence pages

# Logging
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                   # json | text

# Paths
SAMPLES_DIR=samples/raw
PROCESSED_DIR=samples/processed
OUTPUTS_DIR=outputs
EDITS_DIR=edits
USAGE_LOG=usage_log.jsonl
PATTERNS_FILE=app/learned_patterns.json
MODELS_DIR=.models                # TrOCR weights cache
